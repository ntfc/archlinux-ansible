#!/bin/sh
#
# NOTE: this file is generated by ansible. Use that instead of manually editing
# this file
#
# If a terminal emulator is already open, focus on it. If not, execute a new
# one.

# To discover the values for the below variables use `wmctrk -lx`
# * WM_CLASS
TERM_NAME={{ cli_terminal_emulator.name }}
TERM_CLASS={{ cli_terminal_emulator.class }}
TERM_EXECUTABLE={{ cli_terminal_emulator.executable }}

if ! hash wmctrl 2>/dev/null; then
  echo
  echo "Error: wmctrl is not installed! Falling back to xterm"
  echo
  xterm &
else
  # find all windows with urxvt (title, name, class). this might contain a
  # browser window that contains urxvt in the title
  OPEN_TERMS=$(wmctrl -lx | grep $TERM_NAME)
  
  IS_OPEN="no" # default action, execute new TERM_CMD
  # check if an instance of urxvt is indeed open
  while read -r line; do
    NAME_CLASS=$(echo $line | awk '{print $3}') # urxvt => urxvt.URxvt
    if [[ "$NAME_CLASS" == "$TERM_NAME.$TERM_CLASS" ]]; then # focus on current TERM_NAME
      IS_OPEN="yes"
    fi
  done <<< "$OPEN_TERMS"
  
  if [[ "$IS_OPEN" == "no" ]]; then # execute new TERM_CMD
    # if this is running against URxvt, check if the daemon is running so a new
    # child process is created
    if [[ "$TERM_NAME" == "urxvt" ]]; then
      if [[ ! -z `pidof urxvtd` ]]; then # execute urxvt client
        urxvtc &
      else
        urxvt &
      fi
    else
      eval "$TERM_EXECUTABLE" &
    fi
  else # focus on currently open TERM_NAME
    wmctrl -xa "$TERM_NAME"
  fi
fi

